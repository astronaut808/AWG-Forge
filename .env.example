WEBUI_HOST=127.0.0.1
WEBUI_PORT=51821
PASSWORD=change-me
SESSION_SECRET=change-me-long-random-string
SESSION_COOKIE_SECURE=auto
WEBUI_TLS_MODE=off
WEBUI_TLS_CERT_FILE=
WEBUI_TLS_KEY_FILE=
WEBUI_TLS_SERVER_NAME=
WEBUI_TRUST_PROXY_HEADERS=false
WEBUI_TRUSTED_PROXY_CIDRS=
EXTERNAL_INTERFACE=eth0
APPLY_CONFIG=true
PUBLISHED_UDP_PORTS=
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=/etc/awg-forge/audit.log
AUDIT_LOG_MAX_SIZE=5242880
AUDIT_LOG_MAX_FILES=3
DATABASE_MODE=off
DATABASE_PATH=/etc/awg-forge/awg-forge.db
DATABASE_DSN=
DATABASE_RETENTION_DAYS=90
DATABASE_BUSY_TIMEOUT=5s
DATABASE_QUERY_TIMEOUT=2s
DATABASE_MAX_OPEN_CONNS=1
DATABASE_MAX_IDLE_CONNS=1
